<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    android:background="@drawable/login_background_320x600"
    android:visibility="visible"
    tools:context=".LoginForm">


    <Button
        android:id="@+id/instagram"
        android:layout_width="63dp"
        android:layout_height="65dp"
        android:background="@drawable/ic_icons8_instagram__1_"
        android:onClick="instagram"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.235"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fpassword"
        app:layout_constraintVertical_bias="0.765"
        tools:ignore="OnClick,SpeakableTextPresentCheck,UsingOnClickInXml" />

    <Button
        android:id="@+id/vk"
        android:layout_width="63dp"
        android:layout_height="65dp"
        android:background="@drawable/ic_icons8_vk_circled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fpassword"
        app:layout_constraintVertical_bias="0.765"
        tools:ignore="SpeakableTextPresentCheck" />

    <Button
        android:id="@+id/telegram"
        android:layout_width="63dp"
        android:layout_height="65dp"
        android:background="@drawable/ic_icons8_telegram_app"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.764"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fpassword"
        app:layout_constraintVertical_bias="0.765"
        tools:ignore="SpeakableTextPresentCheck" />

    <ImageView
        android:id="@+id/mypass_text"
        android:layout_width="408dp"
        android:layout_height="195dp"
        android:contentDescription="@string/logo_mypass"
        android:src="@drawable/mypass_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/button2"
        android:layout_width="175dp"
        android:layout_height="60dp"
        android:background="@drawable/rounded_button"
        android:drawableEnd="@drawable/ic_uiw_login"
        android:drawingCacheQuality="high"
        android:duplicateParentState="false"
        android:ellipsize="none"
        android:fontFamily="@font/nunito_light"
        android:gravity="center"
        android:paddingEnd="26dip"
        android:singleLine="true"
        android:text="@string/enter"
        android:textColor="#000000"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/password"
        app:layout_constraintVertical_bias="0.048"
        tools:ignore="RtlSymmetry" />

    <TextView
        android:id="@+id/register_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_light"
        android:text="@string/register"
        android:textColor="#FFFFFF"
        android:textColorHighlight="#00FFFFFF"
        android:textColorHint="#00FFFFFF"
        android:textColorLink="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button2"
        app:layout_constraintVertical_bias="0.043" />

    <TextView
        android:id="@+id/fpassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="168dp"
        android:fontFamily="@font/nunito_light"
        android:text="@string/forgot_password"
        android:textColor="#FFFFFF"
        android:textColorHighlight="#00FFFFFF"
        android:textColorHint="#00FFFFFF"
        android:textColorLink="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/register_text"
        app:layout_constraintVertical_bias="0.069" />

    <EditText
        android:id="@+id/login"
        android:layout_width="255dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:autofillHints=""
        android:backgroundTint="#FFFFFF"
        android:drawableStart="@drawable/user"
        android:drawablePadding="6dp"
        android:hint="@string/login"
        android:inputType="text"
        android:textAlignment="gravity"
        android:textColor="#FFFFFF"
        android:textColorHint="#A5A5A5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mypass_text"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/password"
        android:layout_width="255dp"
        android:layout_height="52dp"
        android:layout_marginTop="32dp"
        android:autofillHints=""
        android:backgroundTint="#FFFFFF"
        android:drawableStart="@drawable/ic_carbon_password"
        android:drawablePadding="6dp"
        android:hint="@string/password"
        android:inputType="textPassword"
        android:textAlignment="gravity"
        android:textColor="#FFFFFF"
        android:textColorHint="#A5A5A5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.474"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/login"
        tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>